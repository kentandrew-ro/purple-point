# Copy the values you need into your ignored .envrc file.
export NODE_ENV="development"
export PORT="3000"
export SESSION_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

export DB_HOST="127.0.0.1"
export DB_PORT="3306"
export DB_NAME="purple_point"
export DB_USER="purple_point_user"
export DB_PASSWORD="replace-with-your-database-password"
